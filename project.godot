; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="demo"
config/version="0.1.0"
run/main_scene="res://demo/scenes/levels/demo_main_menu.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://demo/assets/project/icon.svg"

[autoload]

GameState="*res://demo/scripts/game_state.gd"
AchievementManager="*res://demo/scripts/AchievementManager.gd"
AchievementPopup="*res://demo/scenes/ui/AchievementPopup.tscn"
MusicPlayer="*res://demo/scripts/music_player.gd"
AudioSettings="*res://demo/scripts/audio_settings.gd"
Localization="*res://demo/scripts/localization.gd"
InputHelper="*uid://cholww48njaeh"
InputSettings="*res://demo/scripts/input_settings.gd"
PhantomCameraManager="*res://addons/phantom_camera/scripts/managers/phantom_camera_manager.gd"
BetterTerrain="*uid://cut8newgywffy"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="canvas_items"

[editor_plugins]

enabled=PackedStringArray("res://addons/input_helper/plugin.cfg", "res://addons/shader_library/plugin.cfg", "res://addons/phantom_camera/plugin.cfg", "res://addons/better-terrain/plugin.cfg")

